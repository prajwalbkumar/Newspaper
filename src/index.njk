---
layout: layouts/base.njk
permalink: /
title: The Irregular
description: A personal newspaper by Prajwal — dispatches on architecture, BIM automation, travel, code, and making things properly.
---

{# JSON island — all posts for client-side popup #}
<script type="application/json" id="posts-data">
[
{%- for post in collections.allPosts -%}
{"id":{{ post.fileSlug | dump | safe }},"title":{{ (post.data.title or "") | dump | safe }},"deck":{{ (post.data.deck or "") | dump | safe }},"byline":{{ (post.data.byline or "") | dump | safe }},"section":{{ (post.data.section or "") | dump | safe }},"date":{{ post.date | dateShort | dump | safe }},"type":{{ (post.data.type or "") | dump | safe }},"photo":{{ (post.data.photo or "") | dump | safe }},"tags":{{ (post.data.tags or []) | dump | safe }},"body":{{ post.templateContent | dump | safe }},"slug":{{ post.fileSlug | dump | safe }}}
{%- if not loop.last -%},{%- endif -%}
{%- endfor -%}
]
</script>

{% include "components/front-page.njk" %}

{# Column sections grouped by config date dividers #}
{% set dividers = config.content.sectionDividers %}
{% set columnPosts = collections.posts %}

{% set group0 = columnPosts | dateRange(dividers[0].after, "") %}
{% if group0.length > 0 %}
  {% set colData = group0 | groupInto3 %}
  {% include "components/cols-grid.njk" %}
{% endif %}

{% set group1 = columnPosts | dateRange(dividers[1].after, dividers[0].after) %}
{% if group1.length > 0 %}
  {% set sectionLabel = dividers[0].label %}
  {% include "components/section-rule.njk" %}
  {% set colData = group1 | groupInto3 %}
  {% include "components/cols-grid.njk" %}
{% endif %}

{% set group2 = columnPosts | dateRange(dividers[2].after, dividers[1].after) %}
{% if group2.length > 0 %}
  {% set sectionLabel = dividers[1].label %}
  {% include "components/section-rule.njk" %}
  {% set colData = group2 | groupInto3 %}
  {% include "components/cols-grid.njk" %}
{% endif %}

{% set group3 = columnPosts | dateRange("", dividers[2].after) %}
{% if group3.length > 0 %}
  {% set sectionLabel = dividers[2].label %}
  {% include "components/section-rule.njk" %}
  {% set colData = group3 | groupInto3 %}
  {% include "components/cols-grid.njk" %}
{% endif %}

{% set sectionLabel = "Correspondent's Files" %}
{% include "components/section-rule.njk" %}
{% include "components/strip.njk" %}

{% include "components/morgue.njk" %}
{% include "components/footer.njk" %}
{% include "components/popup-overlay.njk" %}
