---
layout: layouts/base.njk
---
<div class="post-page">
  {% if photo %}
  <img class="pp-photo" src="{{ photo }}" alt="{{ title }}">
  {% endif %}
  <div class="pp-bd">
    {% if section %}
    <div class="pp-sec">{{ section | capitalize }}</div>
    {% endif %}
    <h1 class="pp-hed">{{ title }}</h1>
    <div class="pp-rule">
      <div class="lr-thick"></div><div class="lr-dot"></div><div class="lr-thin"></div>
    </div>
    {% if deck %}
    <div class="pp-deck">{{ deck }}</div>
    {% endif %}
    {% if byline %}
    <div class="pp-byline">{{ byline }}</div>
    {% endif %}
    <div class="pp-cols">{{ content | safe }}</div>
  </div>

  {% set relatedPosts = collections.posts | relatedPosts(page.fileSlug, section, 3) %}
  {% if relatedPosts.length > 0 %}
  <div class="pp-related pp-related-outer">
    <div class="pp-related-lbl">Related Dispatches</div>
    <div class="pp-related-grid">
      {% for p in relatedPosts %}
      <a href="{{ p.url }}" class="pp-related-item">
        <div class="pp-related-tag">{{ p.data.section | capitalize }}</div>
        <div class="pp-related-hed">{{ p.data.title }}</div>
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</div>
